# Скопируйте в .env.local и заполните значения.
# Ключи не коммитить в git.

# --- OpenAI (обязательно для чата) ---
OPENAI_API_KEY=

# --- Google Search (вариант A, рекомендуется): SerpAPI ---
# Ключ: https://serpapi.com/manage-api-key (~250 бесплатных запросов/мес)
# Даёт Google Search + Google Lens.
SERPAPI_API_KEY=
SEARCH_PROVIDER=serpapi

# --- Google Search (вариант B): Custom Search API напрямую ---
# SEARCH_PROVIDER=google
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=

# Публичный URL сайта (для Google Lens). Локально — localhost; на Vercel — ваш домен.
PUBLIC_BASE_URL=http://localhost:3000

# --- TTS (опционально) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope
NEXT_PUBLIC_TTS_PROVIDER=azure
